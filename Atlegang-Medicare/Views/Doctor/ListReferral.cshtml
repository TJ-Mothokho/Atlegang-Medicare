@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Referral List";
}

<h1 class="display-5 text-center bold">Referral List</h1>
<hr />

<div class="d-flex justify-content-end">
    <a asp-action="AddReferral" class="btn btn-primary"><i class="fa fa-plus"></i> Add New Referral</a>
</div>

<br />
<div class="card mb-5">
    <div class="card-header">
        <h3 class="card-title">Recent Referrals</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Action</th>
                    <th>Action</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <th>@item.FirstName</th>
                        <th>@item.LastName</th>
                        <th>@item.Email</th>
                        <th>@item.Status</th>
                        <td>
                            <a asp-action="ViewReferral" asp-route-id="@item.UserID" class="btn btn-warning"> <i class="bi bi-card-list"></i> Details</a>
                        </td>
                        <td>
                            <a asp-action="UpdateReferral" asp-route-id="@item.UserID" class="btn btn-primary"> <i class="bi bi-pen"></i> Update</a>
                        </td>
                        <td>
                            <a asp-action="DeleteReferral" asp-route-id="@item.UserID" class="btn btn-danger"> <i class="bi bi-trash"></i> Cancel</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>

