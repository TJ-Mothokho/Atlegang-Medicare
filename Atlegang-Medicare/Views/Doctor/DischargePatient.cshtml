@model DataAccesslayer.Models.View_Models.Doctor.VMPatientFile
@{
    ViewData["Title"] = "Discharge Patient";
}
<h1 class="display-5 text-center bold">Discharge Patient</h1>
<hr />
@if (TempData["SuccessAlert"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@TempData["SuccessAlert"]</strong>Successfully! 
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
else if (TempData["ErrorAlert"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@TempData["ErrorAlert"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row mb-5">
    <div class="col-md-8 mx-auto rounded border p-3">
        <form asp-action="DischargePatient" class="mt-4 " method="post">
            <input asp-for="FileID" type="hidden" />
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">User Identity</label>
                <div class="col-sm-8">
                    <input value=" @Model.PatientID" class="form-control-plaintext" readonly />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">First Name</label>
                <div class="col-sm-8">
                    <input value="@Model.FirstName" class="form-control" readonly />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Last Name</label>
                <div class="col-sm-8">
                    <input value="@Model.LastName" class="form-control" readonly />
                </div>

            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Identity Number</label>
                <div class="col-sm-8">
                    <input value="@Model.IDNumber" class="form-control" readonly />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Date Of Birth</label>
                <div class="col-sm-8">
                    <input value="@Model.DateOfBirth.ToString("MM-dd-yyyy")" class="form-control" readonly />
                </div>

            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Status</label>
                <div class="col-sm-8">
                    <input value="@Model.Status" class="form-control" readonly />
                </div>

            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Arrival Date</label>
                <div class="col-sm-8">
                    <input value="@Model.ArrivalDate" class="form-control" readonly />
                </div>

            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Bed Number</label>
                <div class="col-sm-8">
                    <input value="@Model.BedID" class="form-control" readonly />
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-4 col-form-label"> Ward</label>
                <div class="col-sm-8">
                    <input value="@Model.WardName" class="form-control" readonly />
                </div>

            </div>
            <div class="row">
                <div class="offset-sm-4 col-sm-4 d-grid">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-clockwise"></i> Confirm</button>
                </div>
                <div class="col-sm-4 d-grid">
                    <a class="btn btn-outline-danger" asp-action="ListPatientFiles"><i class="bi bi-x-lg"></i> Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
