@model dynamic;
@{
    ViewData["Title"] = "Patient Note Details";
}
<h1 class="display-5 text-center bold">Patient Note Details</h1>
<hr />

<div class="row">
    <div class="col-md-8 mx-auto rounded border p-3">
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Note Identity</label>
            <div class="col-sm-8">
                <input value="@Model.NoteID" class="form-control-plaintext" readonly />
            </div>
        </div>
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">File Identity</label>
            <div class="col-sm-8">
                <input value="@Model.FileID" class="form-control" readonly />
            </div>
        </div>
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Patient Name</label>
            <div class="col-sm-8">
                <input value="@Model.PatientName" class="form-control" readonly />
            </div>
        </div>
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Description</label>
            <div class="col-sm-8">
                <input value="@Model.Description" class="form-control" readonly />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Issued Date</label>
            <div class="col-sm-8">
                <input value="@Model.Date.ToString("MM-dd-yyyy")" class="form-control" readonly />
            </div>
        </div>
        <div class="col-sm-4 d-grid">
            <a class="btn btn-outline-info btn-block" asp-action="ListPatientNote"> <i class="bi bi-arrow-left"></i> Back to List</a>
        </div>


    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
