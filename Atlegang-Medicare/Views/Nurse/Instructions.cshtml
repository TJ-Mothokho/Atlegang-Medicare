@model dynamic;

@{
    ViewData["Title"] = "Instructions";
}

<h1 class="display-5 text-center bold">Note's Details</h1>
<hr />
<div>
    
    <dl class="row">
      
  
     
     
        <dt class="col-sm-2">
            Description
        </dt>
        <dd class="col-sm-10">
            @Model.Description
        </dd>
        <dt class="col-sm-2">
            Issued Date
        </dt>
        <dd class="col-sm-10">
            @Model.Date.ToString("MM-dd-yyyy")
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-outline-info" asp-action="ListPatientNote">Back to List</a>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


