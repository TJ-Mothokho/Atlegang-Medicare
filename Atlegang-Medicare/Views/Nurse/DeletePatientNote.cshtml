@model DataAccesslayer.Models.View_Models.Doctor.VMNote

@{
    ViewData["Title"] = "Delete Note";
}
<h1 class="display-5 text-center bold">Delete Patient Note</h1>
<hr />
<div class="row">
    <div class="col-md-8 mx-auto rounded border p-3">
        <form asp-action="DeletePatientNote" class="mt-4 " method="post">
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Note Identity</label>
                <div class="col-sm-8">
                    <input asp-for="NoteID" class="form-control-plaintext" readonly />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Patient Name</label>
                <div class="col-sm-8">
                    <input asp-for="PatientName" class="form-control" readonly />
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Description</label>
                <div class="col-sm-8">
                    <input asp-for="Description" class="form-control" readonly />
                </div>

            </div>
           
            <div class="row mb-3">
                <label class="col-sm-4 col-form-label">Issued Date</label>
                <div class="col-sm-8">
                    <input value="@Model.Date.ToString("MM-dd-yyyy")" class="form-control" readonly />
                </div>
            </div>
           
            <div class="row">
                <div class="offset-sm-4 col-sm-4 d-grid">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-trash"></i> Continue</button>
                </div>
                <div class="col-sm-4 d-grid">
                    <a class="btn btn-outline-danger" asp-action="ListPatientNote"><i class="bi bi-x-lg"></i> Cancel</a>
                </div>
            </div>

        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
