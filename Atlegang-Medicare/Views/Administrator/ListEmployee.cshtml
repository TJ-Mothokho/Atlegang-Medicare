@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Employee List";
}


<h1 class="display-5 text-center bold">Employee List</h1>

<hr />
<div class="d-flex justify-content-end">
    <a asp-action="AddEmployee" class="btn btn-primary"><i class="fa fa-plus"></i> Add New Employee</a>
</div>
<br />
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Active Employees</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Phone Number</th>
                    <th>Email</th>
                    <th>Action</th>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <th>@item.FirstName</th>
                        <th>@item.LastName</th>
                        <th>@item.PhoneNumbers</th>
                        <th>@item.Email</th>
                        <td>
                            <a asp-action="ViewEmployee" asp-route-id="@item.UserID" class="btn btn-warning"> <i class="fa fa-file"></i> Details</a>
                        </td>
                        <td>
                            <a asp-action="DeleteEmployee" asp-route-id="@item.UserID" class="btn btn-danger"> <i class="bi bi-x-lg"></i> Cancel</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>

