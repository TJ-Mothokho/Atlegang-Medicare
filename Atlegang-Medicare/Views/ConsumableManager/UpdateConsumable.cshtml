@model DataAccesslayer.Models.Domains.Consumable_and_Script_Manager.Consumable;

@{
    ViewData["Title"] = "Update Consumable";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@TempData["Success"]</strong>Successfully!
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
else if (TempData["ErrorAlert"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@TempData["ErrorAlert"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container">
    <h1 class="display-5 text-center bold">Update Consumable</h1>
    <hr />

    <form asp-action="UpdateConsumable" method="post">
        <div class="row">
            <div class="form-group col-md-12">
                <input class="form-control" asp-for="ConsumableID" hidden />
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="Name">Consumable Name:</label>
                <input class="form-control" asp-for="Name" id="Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="QuantityOnHand">Quantity On Hand:</label>
                <input class="form-control" asp-for="QuantityOnHand" type="number" id="QuantityOnHand" />
                <span asp-validation-for="QuantityOnHand" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="Cost">Cost:</label>
                <input class="form-control" asp-for="Cost" type="number" step="0.01" id="Cost" />
                <span asp-validation-for="Cost" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="SupplierID">Supplier:</label>
                <select class="form-select" asp-for="SupplierID" asp-items="@ViewBag.SupplierList" id="SupplierID">
                    <option value="">Select Supplier</option>
                </select>
                <span asp-validation-for="SupplierID" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="OnHandThreshold">On Hand Threshold:</label>
                <input class="form-control" asp-for="OnHandThreshold" type="number" id="OnHandThreshold" />
                <span asp-validation-for="OnHandThreshold" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6">
                <label class="control-label" asp-for="WardThreshold">Ward Threshold:</label>
                <input class="form-control" asp-for="WardThreshold" type="number" id="WardThreshold" />
                <span asp-validation-for="WardThreshold" class="text-danger"></span>
            </div>

            <div class="form-group col-md-12">
                <button type="submit" class="btn btn-warning"><i class="bi bi-pencil"></i> Update Consumable</button>
            </div>
        </div>
    </form>

    <div class="mt-3">
        <a class="btn btn-primary" asp-action="ViewConsumables"><i class="bi bi-arrow-left-circle"></i> Back to List</a>
    </div>
</div>


<script>
    // JavaScript to handle redirection when the close button is clicked
    document.getElementById('close-alert-btn').addEventListener('click', function () {
        window.location.href = '@Url.Action("ViewConsumables", "ConsumableManager")';
    });
</script>