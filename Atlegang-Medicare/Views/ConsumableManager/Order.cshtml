@model DataAccesslayer.Models.View_Models.ConsumerManager.OrderViewModel;

@{
    ViewData["Title"] = "Orders";
}

<div class="mt-4">
    <div class="row">
        <!-- Main Section -->
        <section class="main-section col-8 border p-3">
            <h1>New Order</h1>
            <p>Place a new order for a consumable</p>

            <form class="form-floating" asp-action="AddToCart">
                <div class="form-group col-6">
                    <label asp-for="ConsumableID" class="form-label">Consumable</label>
                    <select asp-for="ConsumableID" class="form-control" asp-items="@ViewBag.ConsumableList">
                        <option value="">Select Consumable</option>
                    </select>
                    <span asp-validation-for="ConsumableID" class="text-danger"></span>
                </div>

                <div class="form-group col-2">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                </div>

                <div class="form-group col-12">
                    <label asp-for="Message" class="form-label"></label>
                    <textarea asp-for="Message" class="form-control" aria-label="With textarea"></textarea>
                </div>

                <div class="form-group col-12">
                    <button class="btn btn-primary" asp-action="OrderHistory">Order History</button>
                    <button class="btn btn-primary justify-content-end" type="submit">Add to Cart</button>
                </div>
            </form>
        </section>

        <!-- Aside Section -->
        <section class="aside-section col-4 border p-3">
            <div class="cart-card border" style="display:flex; width: auto; padding: 10px; align-items: center;">
                <img src="https://via.placeholder.com/50" alt="Placeholder Image" style="width: 70px; height: 70px; background-color: #f0f0f0; border-radius: 4px; margin-right: 10px;">
                <div class="cart-card-body" style="flex-grow: 1;">
                    <h5 class="cart-card-title">Bandages</h5>
                    <p class="cart-card-text">R20.00 </p>
                </div>
                <div class="ml-auto text-right">
                    <!-- Pencil edit icon -->
                    <a href="#">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                        </svg>
                    </a>
                    <a href="#">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                        </svg>
                    </a>
                    <p class="cart-card-text">x5</p>
                </div>
            </div>
            <div class="col-12" style="display:flex;">
                <div>
                    <p class="text-bold">TOTAL</p>
                </div>
                <div class="ml-auto text-right">
                    <p class="text-bold">R100.00</p>
                </div>
            </div>
            <div>
                <button class="btn btn-primary col-12">Order Now</button>
            </div>
        </section>
    </div>
</div>