@model IEnumerable<dynamic>


@{
    ViewBag.Title = "Patient Visit List";
}
<h1 class="display-5 text-center bold">Patient Visit's List</h1>
<hr />

<br />
<div class="card mb-5">
    <div class="card-header">
        <h3 class="card-title">Recent Scheduled Patients</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Patient Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <th>@item.PatientName</th>
                        <td>
                            <a asp-action="ViewVisit" asp-route-id="@item.VisitID" class="btn btn-warning"> <i class="fa fa-file"></i> Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>

