@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Referrals";
}

<h1 class="display-5 text-center bold">Referred Patients List</h1>


<hr />
<br />
<div class="card">
    <div class="card-header">
        <h1 class="card-title">Recent Referrals</h1>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Identity Number</th>
                    <th>Email</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <th>@item.FirstName</th>
                        <th>@item.LastName</th>
                        <th>@item.IDNumber</th>
                        <th>@item.Email</th>
                        <td>
                            <a class="btn btn-primary" href="@Url.Action("AddPatientFile", "WardAdministrator", new { userID = item.UserID })"><i class="fa fa-plus"></i> Admit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>
<br />
