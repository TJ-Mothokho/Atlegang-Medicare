@model DataAccesslayer.Models.View_Models.WardAdministror.VMPatientMovement

@{
    ViewBag.Title = "Update Movement";
}

<h1 class="display-5 text-center bold">Update Patient Movement</h1>

<hr />
@if (TempData["TempSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@TempData["TempSuccess"]</strong>Successfully!
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
else if (TempData["TempError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@TempData["TempError"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row">
    <div class="col-md-12">
        <form asp-action="UpdateMovement" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="MovementID" type="hidden" />            
            <div class="form-group">
                <label asp-for="PatientName" class="control-label"> Patient Name</label>
                <input asp-for="PatientName" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"> Description <span class="text-danger">*</span></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Date" class="control-label"> Issued Date <span class="text-danger">*</span></label>
                <input asp-for="Date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"> Status <span class="text-danger">*</span></label>
                <select asp-for="Status" class="form-control" asp-items="ViewBag.StatusValue">
                    <option value="">
                        Select Status...
                    </option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group d-flex">
                <input type="submit" value="Save" class="btn btn-primary mr-3" />
                <a asp-action="ListMovements" class="btn btn-outline-warning">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
