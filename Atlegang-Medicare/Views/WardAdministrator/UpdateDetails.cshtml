@model Atlegang_Medicare.ViewModels.VMPatient

@{
    ViewData["Title"] = "Patient Details";
}
<h1 class="display-5 text-center bold">Update Patient's Details</h1>


<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="UpdateReferral" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="@Model.UserID" type="hidden" />
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="FirstName" class="control-label"></label>
                        <input asp-for="FirstName" value="@Model.FirstName" class="form-control" disabled />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="LastName" class="control-label"></label>
                        <input asp-for="LastName" value="@Model.LastName" class="form-control" disabled />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="IDNumber" class="control-label"></label>
                        <input asp-for="IDNumber" id="IDNumber" value="@Model.IDNumber" type="number" class="form-control" readonly disabled />
                        <span asp-validation-for="IDNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="DateOfBirth" class="control-label"></label>
                        <input asp-for="DateOfBirth" id="DateOfBirth" class="form-control" readonly disabled />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Gender" class="control-label"></label>
                        <select asp-for="Gender" value="@Model.Gender" class="form-control" asp-items="ViewBag.GenderList  ">
                            <option value="">Select Gender</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="SuburbID" class="control-label"></label>
                        <select asp-for="SuburbID" value="@Model.SuburbID" class="form-control" asp-items="ViewBag.SuburbList">
                            <option value="">Select Suburb</option>
                        </select>
                        <span asp-validation-for="SuburbID" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="ResidentialAddress" class="control-label"></label>
                        <input asp-for="ResidentialAddress" value="@Model.ResidentialAddress" class="form-control" />
                        <span asp-validation-for="ResidentialAddress" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="PhoneNumbers" class="control-label"></label>
                        <input asp-for="PhoneNumbers" value="@Model.PhoneNumbers" class="form-control" />
                        <span asp-validation-for="PhoneNumbers" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Email" class="control-label"></label>
                        <input asp-for="Email" value="@Model.Email" class="form-control" readonly />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <br />
            <br />
            <div class="form-group">
                <a asp-action="AddPatientFile"  type="submit"  class="btn btn-primary"> Continue</a>
            </div>
            
        </form>
    </div>
</div>


<script src="~/js/site.js"></script>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}